# ===== Servidor =====
PORT=3333
# Segredo que vai na URL dos webhooks (invente um valor longo e aleatório).
WEBHOOK_TOKEN=troque-por-um-segredo-aleatorio-longo
# DEBUG=true   # descomente para logs detalhados

# ===== Chatwoot =====
# URL base da sua instância (sem barra no final).
CHATWOOT_BASE_URL=https://chat.seudominio.com
# ID da conta (aparece na URL: /app/accounts/<ID>/...).
CHATWOOT_ACCOUNT_ID=1
# Token de acesso do agente/bot: Perfil -> Configurações -> Access Token.
CHATWOOT_API_ACCESS_TOKEN=seu_access_token_do_chatwoot
# ID da caixa de entrada do tipo "API" que você criou.
CHATWOOT_INBOX_ID=1

# ===== Z-API =====
ZAPI_INSTANCE_ID=sua_instancia
ZAPI_INSTANCE_TOKEN=seu_token_da_instancia
# "Account Security Token" (header Client-Token) do painel da Z-API.
ZAPI_CLIENT_TOKEN=seu_client_token
ZAPI_BASE_URL=https://api.z-api.io

# ===== Comportamento =====
# Encaminhar mensagens enviadas pelo próprio número (cuidado: pode gerar loop). Padrão: false
FORWARD_FROM_ME=false
# Ignorar mensagens de grupos. Padrão: true
IGNORE_GROUPS=true
# Baixar e reenviar mídias para o Chatwoot. Se false, envia apenas o link. Padrão: true
HANDLE_MEDIA=true
